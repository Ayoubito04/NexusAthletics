{
  "expo": {
    "name": "Nexus Fitness",
    "slug": "nexus-fitness",
    "scheme": "nexus-fitness",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMotionUsageDescription": "Nexus Fitness necesita acceso a tu actividad física para registrar tus entrenamientos.",
        "NSLocationWhenInUseUsageDescription": "Nexus Fitness usa tu ubicación para encontrar gimnasios cercanos y personalizar tu experiencia.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Nexus Fitness usa tu ubicación para seguimiento de actividad en segundo plano."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "adjustResize",
      "package": "com.nexusia.fitness",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nexus Fitness usa tu ubicación para encontrar gimnasios cercanos y personalizar tu experiencia.",
          "locationAlwaysAndWhenInUsePermission": "Nexus Fitness usa tu ubicación para seguimiento de actividad en segundo plano.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-image-picker",
      "expo-notifications",
      "@react-native-google-signin/google-signin",
      [
        "expo-sensors",
        {
          "motionPermission": "Esta app necesita acceso a tu actividad física para contar pasos automáticamente."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.nexusia.fitness",
          "enableGooglePay": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "726f4f3d-bb01-4b3c-abdb-98aac09d7fd4"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/726f4f3d-bb01-4b3c-abdb-98aac09d7fd4"
    }
  }
}
